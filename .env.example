# Server
PORT=8000
NODE_ENV=development
JWT_SECRET=change-me-to-a-long-random-string
APP_URL=http://127.0.0.1:8000

# PostgreSQL (docker-compose default)
DATABASE_URL=postgresql://examedge:examedge@localhost:5432/examedge

# Redis (optional — falls back to PostgreSQL for OTP cache)
REDIS_URL=redis://localhost:6379

# Phone OTP — Termii (https://termii.com) or leave empty for dev console OTP
TERMII_API_KEY=
TERMII_SENDER_ID=ExamEdge

# Paystack — https://dashboard.paystack.com
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_PUBLIC_KEY=pk_test_xxx

# Anthropic Claude — AI tutor & study plans
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# WhatsApp Cloud API — Meta Business
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=examedge_verify_token

# Google OAuth (optional)
GOOGLE_CLIENT_ID=

# Email — Resend weekly parent reports
RESEND_API_KEY=
