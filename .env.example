# Server
PORT=8000
NODE_ENV=development
APP_URL=http://127.0.0.1:8000
FRONTEND_URL=http://localhost:8000

# Database — DEFAULT: in-memory (no Docker). Data saved to data/examedge-db.json
USE_PG_MEM=true

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# OTP (Termii - Nigeria SMS)
TERMII_API_KEY=your-termii-api-key-here
TERMII_SENDER_ID=ExamEdge

# Payments (Paystack)
PAYSTACK_SECRET_KEY=sk_test_your-paystack-key-here
PAYSTACK_PUBLIC_KEY=pk_test_your-paystack-key-here

# AI (Anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# WhatsApp (Meta Cloud API)
WHATSAPP_TOKEN=your-whatsapp-token-here
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id-here
WHATSAPP_VERIFY_TOKEN=examedge-webhook-verify-2026
